            height="auto"
            axis="column"
            grow="1.0"
            backgroundColor="@theme/color/card"
            cornerRadius="8"
            marginBottom="30">

            <brls:SelectorCell
                id="settings/language"
                title="@i18n/akira/settings/language"
                marginLeft="15"
                marginRight="15"/>

            <brls:Label
                text="@i18n/akira/settings/language_desc"
                fontSize="14"
                textColor="#666666"
                marginLeft="15"
                marginTop="5"
                marginBottom="10"/>

        </brls:Box>

        <brls:Header
