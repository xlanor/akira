<brls:Box
    width="auto"
    height="auto"
    grow="1.0">

    <brls:ScrollingFrame
        width="auto"
        height="auto"
        grow="1.0">

        <brls:Box
            width="auto"
            height="auto"
            axis="column"
            paddingTop="@style/brls/tab_frame/content_padding_top_bottom"
